# --- Qiita ---
# Qiita 個人用アクセストークン（write_qiita スコープ）
# 取得: https://qiita.com/settings/applications → 個人用アクセストークン → 発行
QIITA_TOKEN=

# --- Zenn ---
# Zenn と GitHub 連携されているローカルクローンのパス（articles/ 配下に MD が並ぶリポ）
# 例: /Users/you/Repo/my/zenn-content
ZENN_REPO_PATH=
ZENN_BRANCH=main
# CI環境などZENN_REPO_PATHが存在しない場合、このURLからclone する
# 例: https://x-access-token:TOKEN@github.com/you/zenn-content.git
ZENN_REPO_URL=
# git 操作時の commit author（未指定ならグローバル git config を使う）
ZENN_AUTHOR_NAME=
ZENN_AUTHOR_EMAIL=
